# version: 1.8.2
# description: Example environment variables for local and production runs.
# updated: 2026-05-15
APP_ENV=local
APP_DEBUG=true
APP_SECRET_KEY=change_me
ENCRYPTION_KEY=PASTE_FERNET_KEY_HERE

BOT_TOKEN=0000000000:example
ADMIN_TELEGRAM_IDS=123456789

POSTGRES_DB=mpcontrol_db
POSTGRES_USER=mpcontrol_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://mpcontrol_user:change_me@postgres:5432/mpcontrol_db

REDIS_URL=redis://redis:6379/0

WB_BASE_MARKETPLACE_URL=https://marketplace-api.wildberries.ru
WB_BASE_COMMON_URL=https://common-api.wildberries.ru
WB_BASE_CONTENT_URL=https://content-api.wildberries.ru
WB_BASE_ANALYTICS_URL=https://seller-analytics-api.wildberries.ru
WB_BASE_FINANCE_URL=https://finance-api.wildberries.ru
WB_BASE_STATISTICS_URL=https://statistics-api.wildberries.ru

OZON_BASE_URL=https://api-seller.ozon.ru
OZON_COMMISSIONS_SOURCE_URL=https://seller-edu.ozon.ru/libra/commissions-tariffs/commissions-tariffs-ozon/komissii-tovary-uslugi
# auto = HTTP first, then browser fallback; http = HTTP only; browser = Playwright only; manual = upload only
OZON_COMMISSIONS_FETCH_MODE=auto
OZON_COMMISSIONS_BROWSER_FALLBACK_ENABLED=1
OZON_COMMISSIONS_BROWSER_HEADLESS=1
OZON_COMMISSIONS_BROWSER_TIMEOUT_SECONDS=60
OZON_COMMISSIONS_DOWNLOAD_DIR=/app/runtime/ozon_commissions
OZON_COMMISSIONS_COOKIE_ENABLED=0
OZON_COMMISSIONS_COOKIE_FILE=/app/runtime/secret/ozon_seller_edu_cookies.json

ORDER_POLL_INTERVAL_SECONDS=180
BACKFILL_DEFAULT_DAYS=30
BACKFILL_CHUNK_DAYS=7
# Для Telegram inline URL нужен публичный HTTPS-адрес. localhost Telegram отклоняет.
WEB_BASE_URL=https://example.com
WEB_APP_BASE_URL=https://example.com
API_BASE_URL=https://api.example.com
PUBLIC_SITE_URL=https://example.com
# Зарезервировано для будущего Telegram webhook. Сейчас бот работает через long polling.
BOT_WEBHOOK_BASE_URL=https://bot.example.com
WEB_LOGIN_TOKEN_TTL_MINUTES=10
WEB_SESSION_TTL_HOURS=168
DAILY_REPORT_HOUR=9
DEFAULT_TAX_RATE=0.06
DEFAULT_PACKAGE_COST=0
LOG_LEVEL=INFO

# YooKassa payment integration
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://example.com/payment/success
YOOKASSA_WEBHOOK_URL=https://example.com/webhooks/yookassa
# Для production проверьте, что webhook payment.succeeded/payment.canceled добавлен в ЛК ЮKassa.
# WEB_BASE_URL используется для return URL после оплаты и webhook URL
# Должен быть публичным HTTPS-адресом (не localhost)

# Wildberries API permissions
# seller-info: общий WB API token.
# balance и financial reports: токен WB с категорией Finance.
# Calendar promotions: токен WB с категорией Prices and Discounts.

# Wildberries MRC (recommended retail price) pricing
# МРЦ — целевая цена со скидкой на WB. Цена до скидки = МРЦ × множитель.
WB_MRC_PROMO_MAX_DISCOUNT_PERCENT=10
WB_PRICE_BEFORE_DISCOUNT_MULTIPLIER=4

# Wildberries promotions sync (daily at 00:15 Moscow time)
WB_PROMOTIONS_SYNC_ENABLED=true
WB_PROMOTIONS_SYNC_TIME=00:15
WB_PROMOTIONS_SYNC_TIMEZONE=Europe/Moscow
WB_PROMOTIONS_HISTORY_RETENTION_DAYS=90
WB_PROMOTIONS_PAGE_LIMIT=1000

# Support contact
SUPPORT_TELEGRAM_USERNAME=mpcontrol_support

# Deployment / update
DEPLOY_PROJECT_DIR=/opt/example-app
DEPLOY_LOG_DIR=/opt/example-app/logs/deploy
DEPLOY_RUNTIME_DIR=/opt/example-app/runtime
BACKUP_DIR=/opt/example-app/backups
BACKUP_RETENTION_DAYS=30
ENABLE_TELEGRAM_DEPLOY_NOTIFICATIONS=true
# Безопасный host-trigger: бот пишет trigger-файл, systemd на сервере запускает deploy/update.sh.
ENABLE_TELEGRAM_DEPLOY_COMMANDS=false
TELEGRAM_DEPLOY_MODE=trigger
DEPLOY_UPDATE_COMMAND="bash deploy/update.sh --non-interactive"
DEPLOY_UPDATE_TRIGGER_FILE=/opt/example-app/runtime/telegram_update_request.json
DEPLOY_METADATA_FILE=/opt/example-app/runtime/deploy_metadata.json
HEALTHCHECK_RETRIES=20
HEALTHCHECK_INTERVAL_SECONDS=3
